---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9
        http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">
{% for page in site.pages %}
{% assign url = page.url | replace: 'index.html', '' %}
{% unless url contains 'sitemap' or url contains 'feed' or page.sitemap.exclude == 'yes' %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ url }}</loc>
    <lastmod>{{ page.date | default: site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>{% if url == '/' %}1.0{% else %}0.8{% endif %}</priority>
  </url>
{% endunless %}
{% endfor %}
</urlset>
